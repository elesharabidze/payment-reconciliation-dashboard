# ─────────────────────────────────────────────────────────────
# Supabase connection
# Copy this file to `.env.local` and fill in values from your
# Supabase project: Dashboard → Project Settings → API
# ─────────────────────────────────────────────────────────────

# Project URL, e.g. https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Service-role key (server-only secret — NEVER expose to the browser).
# All database access in this app runs server-side, so the anon key
# is not required.
SUPABASE_SERVICE_ROLE_KEY=
